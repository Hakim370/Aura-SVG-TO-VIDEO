rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'hakimmia370@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Collection Rules ---

    // Connection test document
    match /test/connection {
      allow read: if true;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if isOwner(userId);
      
      allow update: if (isOwner(userId) && 
                         incoming().get('role', 'user') == existing().get('role', 'user') &&
                         incoming().get('exportLimit', 5) == existing().get('exportLimit', 5) &&
                         incoming().get('isBlocked', false) == existing().get('isBlocked', false))
                     || isAdmin();
    }

    match /exports/{exportId} {
      allow get: if isOwner(existing().userId) || isAdmin();
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      allow create: if isSignedIn() && 
                       incoming().userId == request.auth.uid &&
                       incoming().createdAt == request.time &&
                       (!get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isBlocked', false)) &&
                       (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('exportCount', 0) < get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('exportLimit', 5));
      
      allow update, delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() && adminId == request.auth.uid;
    }
  }
}
